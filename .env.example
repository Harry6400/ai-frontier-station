# Backend database
DB_URL=jdbc:mysql://localhost:3306/ai_frontier_station?useUnicode=true&characterEncoding=utf-8&serverTimezone=Asia/Shanghai
DB_USERNAME=root
DB_PASSWORD=your_mysql_password

# Encryption master key for API credential storage
# REQUIRED for production! Minimum 16 characters, recommended 32+ characters
# Generate with: openssl rand -base64 32
API_MASTER_KEY=

# JWT secret for admin authentication
# REQUIRED for production! Minimum 32 characters
# Generate with: openssl rand -base64 32
JWT_SECRET=

# Optional runtime capabilities
# You can also configure these in the admin "API 设置" page after the backend starts.
# Keys entered in the admin UI will be encrypted and stored in the database.
DASHSCOPE_API_KEY=your_bailian_api_key
GITHUB_TOKEN=your_github_token
MIMO_API_KEY=your_mimo_api_key
